# Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# JWT — gunakan secret yang kuat, minimal 32 karakter
JWT_SECRET="ganti-dengan-random-string-min-32-karakter"
JWT_REFRESH_SECRET="ganti-dengan-random-string-lain-min-32-karakter"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# File Upload — ganti ke S3/R2 untuk production
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="52428800"

# Server
PORT=3000
NODE_ENV="development"

# CORS — update untuk domain production
CORS_ORIGIN="http://localhost:5173,http://localhost:8081"
